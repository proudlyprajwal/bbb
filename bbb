#include <stdio.h>
#include <omp.h>

#define N 1000000

int main() {
    static int vec[N];
    int scalar = 7;

    #pragma omp parallel for
    for (int i = 0; i < N; i++) {
        vec[i] = i + scalar;
    }

    printf("Vector addition complete. vec[0]=%d, vec[%d]=%d\n", vec[0], N-1, vec[N-1]);
    return 0;
}




