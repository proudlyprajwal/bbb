#include <stdio.h>
#include <omp.h>

int main() {
    long steps = 1000000;
    double step = 1.0 / steps;
    double pi = 0.0;

    #pragma omp parallel for reduction(+:pi)
    for(long i = 0; i < steps; i++) {
        double x = (i + 0.5) * step;
        pi += 4.0 / (1.0 + x * x);
    }

    pi *= step;

    printf("Calculated Pi: %f\n", pi);
    return 0;
}





