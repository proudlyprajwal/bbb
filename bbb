#include <stdio.h>
#include <stdlib.h>
#include <omp.h>

#define SIZE 200

void benchmark_static(int chunk_size) {
    double A[SIZE], scalar = 5.0;
    int i;

    for (i = 0; i < SIZE; i++)
        A[i] = (double)i;

    double start = omp_get_wtime();

    #pragma omp parallel for schedule(static, chunk_size) num_threads(4)
    for (i = 0; i < SIZE; i++) {
        A[i] += scalar;
    }

    double end = omp_get_wtime();

    printf("Schedule: STATIC, Chunk Size: %d, Time: %f seconds\n",
           chunk_size, end - start);
}

void benchmark_dynamic(int chunk_size) {
    double A[SIZE], scalar = 5.0;
    int i;

    for (i = 0; i < SIZE; i++)
        A[i] = (double)i;

    double start = omp_get_wtime();

    #pragma omp parallel for schedule(dynamic, chunk_size) num_threads(4)
    for (i = 0; i < SIZE; i++) {
        A[i] += scalar;
    }

    double end = omp_get_wtime();

    printf("Schedule: DYNAMIC, Chunk Size: %d, Time: %f seconds\n",
           chunk_size, end - start);
}

void demonstrate_nowait() {
    double A[SIZE], B[SIZE], scalar = 5.0;
    int i;

    for (i = 0; i < SIZE; i++) {
        A[i] = (double)i;
        B[i] = (double)i;
    }

    printf("\nDemonstrating nowait clause:\n");

    #pragma omp parallel num_threads(4)
    {
        #pragma omp for nowait
        for (i = 0; i < SIZE/2; i++) {
            A[i] += scalar;
            // Thread finishing here won't wait for others and can proceed
        }

        #pragma omp for
        for (i = SIZE/2; i < SIZE; i++) {
            B[i] += scalar;
        }
    }

    printf("Nowait demo\n");
}

int main() {
    int chunk_sizes[] = {1, 5, 10, 20, 50};
    int i;

    printf("1D Vector Scalar Addition Benchmark (Size=%d)\n", SIZE);

    // Serial time for speedup calculation (approximate)
    double A[SIZE], scalar = 5.0;
    double start = omp_get_wtime();
    for (i = 0; i < SIZE; i++)
        A[i] += scalar;
    double serial_time = omp_get_wtime() - start;

    printf("Serial Time: %f seconds\n\n", serial_time);

    for (i = 0; i < 5; i++) {
        benchmark_static(chunk_sizes[i]);
    }

    printf("\n");

    for (i = 0; i < 5; i++) {
        benchmark_dynamic(chunk_sizes[i]);
    }

    demonstrate_nowait();

    return 0;
}
